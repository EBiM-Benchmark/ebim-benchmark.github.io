{
  "name": "ebim-benchmark-site",
  "version": "0.0.0",
  "private": true,
  "description": "EBiM Benchmark website — Eleventy build (Phase 0 migration; output is byte-for-byte equivalent to the hand-authored static site).",
  "type": "module",
  "scripts": {
    "build": "eleventy",
    "serve": "eleventy --serve",
    "verify": "node scripts/verify.mjs",
    "verify:zh": "node scripts/verify-zh.mjs --no-build",
    "verify:all": "node scripts/verify.mjs && node scripts/verify-zh.mjs --no-build"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.0"
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  }
}
