---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
# Locale-aware sitemap, gated PER PAGE on site.zhPublished[pair] (the i18nKey
# map in src/_data/site.json). The four EN URLs are always listed. A /zh/ URL is
# listed iff its pair's flag is true; an EN URL gets <xhtml:link> hreflang
# alternates iff its pair's flag is true. With all four pairs published as of
# Phase 2c: 8 URLs (4 EN + 4 /zh/), each pair carrying reciprocal
# en/zh-Hans/x-default alternates on both its EN and /zh/ rows. (Return a flag to
# false and that /zh/ row drops out and its pair's alternates disappear.)
# The xhtml namespace is emitted whenever any page is published. The alternate
# hrefs mirror HREFLANG_PAIRS in src/_data/eleventyComputed.js. 404 /
# contact-success (EN + /zh/) / contact-test are intentionally excluded.
sitemap:
  urls:
    - { loc: "https://ebim-benchmark.github.io/", lastmod: "2026-06-15", changefreq: "weekly", priority: "1.0", pair: "index" }
    - { loc: "https://ebim-benchmark.github.io/competition.html", lastmod: "2026-06-15", changefreq: "weekly", priority: "0.9", pair: "competition" }
    - { loc: "https://ebim-benchmark.github.io/workshop.html", lastmod: "2026-06-15", changefreq: "weekly", priority: "0.9", pair: "workshop" }
    - { loc: "https://ebim-benchmark.github.io/contact.html", lastmod: "2026-06-15", changefreq: "monthly", priority: "0.6", pair: "contact" }
    - { loc: "https://ebim-benchmark.github.io/zh/", lastmod: "2026-06-15", changefreq: "weekly", priority: "1.0", pair: "index", zh: true }
    - { loc: "https://ebim-benchmark.github.io/zh/competition.html", lastmod: "2026-06-15", changefreq: "weekly", priority: "0.9", pair: "competition", zh: true }
    - { loc: "https://ebim-benchmark.github.io/zh/workshop.html", lastmod: "2026-06-15", changefreq: "weekly", priority: "0.9", pair: "workshop", zh: true }
    - { loc: "https://ebim-benchmark.github.io/zh/contact.html", lastmod: "2026-06-15", changefreq: "monthly", priority: "0.6", pair: "contact", zh: true }
  alternates:
    index:
      - { hreflang: "en", href: "https://ebim-benchmark.github.io/" }
      - { hreflang: "zh-Hans", href: "https://ebim-benchmark.github.io/zh/" }
      - { hreflang: "x-default", href: "https://ebim-benchmark.github.io/" }
    competition:
      - { hreflang: "en", href: "https://ebim-benchmark.github.io/competition.html" }
      - { hreflang: "zh-Hans", href: "https://ebim-benchmark.github.io/zh/competition.html" }
      - { hreflang: "x-default", href: "https://ebim-benchmark.github.io/competition.html" }
    workshop:
      - { hreflang: "en", href: "https://ebim-benchmark.github.io/workshop.html" }
      - { hreflang: "zh-Hans", href: "https://ebim-benchmark.github.io/zh/workshop.html" }
      - { hreflang: "x-default", href: "https://ebim-benchmark.github.io/workshop.html" }
    contact:
      - { hreflang: "en", href: "https://ebim-benchmark.github.io/contact.html" }
      - { hreflang: "zh-Hans", href: "https://ebim-benchmark.github.io/zh/contact.html" }
      - { hreflang: "x-default", href: "https://ebim-benchmark.github.io/contact.html" }
---
<?xml version="1.0" encoding="UTF-8"?>
{%- set anyPublished = site.zhPublished.index or site.zhPublished.competition or site.zhPublished.workshop or site.zhPublished.contact %}
{%- if anyPublished %}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
{%- else %}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{%- endif %}
{%- for u in sitemap.urls %}
{%- if (not u.zh) or site.zhPublished[u.pair] %}
  <url>
    <loc>{{ u.loc }}</loc>
    <lastmod>{{ u.lastmod }}</lastmod>
    <changefreq>{{ u.changefreq }}</changefreq>
    <priority>{{ u.priority }}</priority>
{%- if u.pair and site.zhPublished[u.pair] %}
{%- for alt in sitemap.alternates[u.pair] %}
    <xhtml:link rel="alternate" hreflang="{{ alt.hreflang }}" href="{{ alt.href }}" />
{%- endfor %}
{%- endif %}
  </url>
{%- endif %}
{%- endfor %}
</urlset>
