---
permalink: "/zh/workshop.html"
bodyClass: "page-workshop"
keywords: "具身智能研讨会, 机器人操作研讨会, 机器人圆桌讨论, 移动操作报告, 双臂操作基准, 基础模型, 真实世界移动操作, 全身操作"
canonical: "https://ebim-benchmark.github.io/zh/workshop.html"
headComments: true
backToTop: true
i18nKey: workshop
---
{% extends "layouts/base.njk" %}

{% block headStructured %}
  <!-- Open Graph -->
  <meta property="og:type"            content="website" />
  <meta property="og:site_name"       content="EBiM Benchmark" />
  <meta property="og:url"             content="https://ebim-benchmark.github.io/zh/workshop.html" />
  <meta property="og:title"           content="{{ pageMeta.ogTitle | safe }}" />
  <meta property="og:description"     content="{{ pageMeta.ogDescription | safe }}" />
  <meta property="og:image"           content="https://ebim-benchmark.github.io/img/og-cover.png" />
  <meta property="og:image:width"     content="1200" />
  <meta property="og:image:height"    content="630" />
  <meta property="og:image:alt"       content="EBiM Benchmark — 迈向面向真实世界具身双臂操作的全球协同基准" />
  <meta property="og:locale"          content="zh_CN" />

  <!-- Twitter / X Card -->
  <meta name="twitter:card"           content="summary_large_image" />
  <meta name="twitter:title"          content="{{ pageMeta.twitterTitle | safe }}" />
  <meta name="twitter:description"    content="{{ pageMeta.twitterDescription | safe }}" />
  <meta name="twitter:image"          content="https://ebim-benchmark.github.io/img/og-cover.png" />
  <meta name="twitter:image:alt"      content="EBiM Benchmark — 迈向面向真实世界具身双臂操作的全球协同基准" />
{% include "jsonld.njk" %}
{% endblock %}

{% block headStyle %}{% raw %}
  <!-- Critical CSS inlined to prevent FOUC -->
  <style>
    /* Fade-in default state — must be set before JS runs */
    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity .55s ease, transform .55s ease; }
    .fade-in.visible { opacity: 1; transform: none; }
    /* Stagger children inside a fade-in parent */
    .fade-in > *:nth-child(2) { transition-delay: .08s; }
    .fade-in > *:nth-child(3) { transition-delay: .16s; }
    .fade-in > *:nth-child(4) { transition-delay: .24s; }
    .fade-in > *:nth-child(5) { transition-delay: .32s; }
    .fade-in > *:nth-child(6) { transition-delay: .40s; }
    /* Active nav link */
    .nav-links a.active { color: var(--accent) !important; }
    /* Back to top */
    #back-to-top {
      position: fixed; bottom: 2rem; right: 1.5rem;
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--accent, #00d4ff); color: #0a0e1a;
      border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; visibility: hidden; transform: translateY(12px);
      transition: opacity .3s, visibility .3s, transform .3s, background .2s, box-shadow .2s;
      z-index: 998;
      box-shadow: 0 4px 18px rgba(0,212,255,.35);
    }
    #back-to-top.visible { opacity: 1; visibility: visible; transform: none; }
    #back-to-top:hover { background: #fff; box-shadow: 0 6px 24px rgba(0,212,255,.45); }
    #back-to-top:focus-visible { outline: 2px solid #00d4ff; outline-offset: 3px; }
    #back-to-top svg { pointer-events: none; }

    /* ── Sub-page hero (shorter than home #home) ──
       Selector specificity bumped to (1,1,0) via `#home.subhero` to override
       `#home { min-height: 100vh; padding: ... }` from the global stylesheet.
       Pseudo-element rules likewise override #home::before/::after. */
    #home.subhero {
      min-height: 40vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      background: var(--bg-dark);
      overflow: hidden;
      padding: calc(var(--nav-h) + 2.5rem) 0 3rem;
      box-sizing: border-box;
    }
    #home.subhero::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(0,212,255,.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,212,255,.07) 1px, transparent 1px);
      background-size: 60px 60px;
      animation: none;
      pointer-events: none;
    }
    #home.subhero::after {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(0,212,255,.10) 0%, transparent 70%);
      pointer-events: none;
    }
    .subhero-content {
      position: relative; z-index: 1;
      text-align: center;
      max-width: 820px;
      padding: 1.25rem 1.5rem;
    }
    .breadcrumb {
      display: inline-block;
      font-size: .78rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(255,255,255,.55);
      margin-bottom: 1rem;
    }
    .breadcrumb a {
      color: rgba(255,255,255,.55);
      transition: color .2s;
    }
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb-sep { margin: 0 .55rem; opacity: .5; }
    .breadcrumb-current { color: var(--accent); }
    .subhero-title {
      font-size: clamp(1.7rem, 3.6vw, 2.6rem);
      color: #fff;
      font-weight: 800;
      line-height: 1.18;
      margin-bottom: .9rem;
      letter-spacing: -.01em;
    }
    .subhero-subtitle {
      font-size: clamp(.95rem, 1.6vw, 1.1rem);
      color: rgba(255,255,255,.72);
      margin-bottom: .9rem;
      max-width: 640px;
      margin-left: auto; margin-right: auto;
    }
    .subhero-date {
      font-size: .85rem;
      font-weight: 600;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.6rem;
    }
    .subhero-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    @media (max-width: 700px) {
      #home.subhero { min-height: 50vh; padding-top: calc(var(--nav-h) + 1.5rem); padding-bottom: 2rem; }
    }

    /* ── Workshop overview prose ── */
    .workshop-overview-text {
      max-width: 880px;
      margin: 1.5rem auto 0;
      font-size: 1.05rem;
      line-height: 1.75;
      color: var(--text-body, #2c3243);
      text-align: left;
    }
    .workshop-overview-text a {
      color: var(--accent);
      font-weight: 600;
    }
    .workshop-overview-text a:hover { text-decoration: underline; }

    /* ── Invited Talks grid ── */
    .talks-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
      margin-top: 2.5rem;
    }
    .talk-card {
      background: #fff;
      border: 1px solid rgba(10,14,26,.08);
      border-radius: 14px;
      padding: 1.6rem 1.25rem 1.4rem;
      text-align: center;
      transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .talk-card:hover {
      transform: translateY(-4px);
      border-color: rgba(0,212,255,.45);
      box-shadow: 0 10px 30px rgba(10,14,26,.08);
    }
    .talk-card .org-avatar {
      margin-bottom: .9rem;
    }
    .talk-speaker-name {
      font-size: 1.05rem;
      font-weight: 800;
      color: var(--bg-dark);
      margin-bottom: .25rem;
    }
    .talk-speaker-affil {
      font-size: .82rem;
      color: var(--text-muted);
      margin-bottom: .9rem;
      line-height: 1.4;
    }
    .talk-title {
      font-size: .95rem;
      font-weight: 600;
      line-height: 1.5;
      color: var(--accent);
      font-style: italic;
      margin-top: auto;
    }

    /* ── Panel Discussion ── */
    .panel-section .panel-header {
      max-width: 880px;
      margin: 2rem auto 1.25rem;
      padding: 1.4rem 1.5rem;
      background: linear-gradient(135deg, rgba(0,212,255,.08), rgba(0,212,255,.02));
      border: 1px solid rgba(0,212,255,.25);
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.25rem;
      flex-wrap: wrap;
    }
    .panel-header-title {
      font-size: 1.15rem;
      font-weight: 800;
      color: var(--bg-dark);
      letter-spacing: -.005em;
    }
    .panel-header-time {
      font-size: .85rem;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .panel-people {
      max-width: 880px;
      margin: 0 auto 1.5rem;
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 1.5rem;
    }
    @media (max-width: 700px) {
      .panel-people { grid-template-columns: 1fr; }
    }
    .panel-people-block {
      background: #fff;
      border: 1px solid rgba(10,14,26,.08);
      border-radius: 12px;
      padding: 1.1rem 1.25rem;
    }
    .panel-people-label {
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: .65rem;
    }
    .panel-person {
      display: flex;
      align-items: center;
      gap: .7rem;
      margin-bottom: .55rem;
    }
    .panel-person:last-child { margin-bottom: 0; }
    .panel-person-name {
      font-weight: 700;
      color: var(--bg-dark);
      font-size: .95rem;
    }
    .panel-person-affil {
      color: var(--text-muted);
      font-size: .82rem;
      margin-left: .35rem;
    }
    .panel-themes {
      max-width: 880px;
      margin: 0 auto;
      background: #fff;
      border: 1px solid rgba(10,14,26,.08);
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
    }
    .panel-themes-label {
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: .8rem;
    }
    .panel-themes ul {
      margin: 0;
      padding-left: 1.2rem;
      color: var(--text-body, #2c3243);
      font-size: .95rem;
      line-height: 1.65;
    }
    .panel-themes li { margin-bottom: .35rem; }
    .panel-themes li:last-child { margin-bottom: 0; }

    /* ── Dissemination ── */
    .dissemination-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.25rem;
      margin-top: 2rem;
    }
    .diss-card {
      background: #fff;
      border: 1px solid rgba(10,14,26,.08);
      border-radius: 14px;
      padding: 1.4rem 1.25rem;
      text-align: left;
      transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    }
    .diss-card:hover {
      transform: translateY(-3px);
      border-color: rgba(0,212,255,.45);
      box-shadow: 0 8px 24px rgba(10,14,26,.06);
    }
    .diss-icon {
      width: 38px; height: 38px;
      border-radius: 10px;
      background: rgba(0,212,255,.12);
      color: var(--accent);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: .9rem;
    }
    .diss-card h3 {
      font-size: 1rem;
      font-weight: 800;
      color: var(--bg-dark);
      margin-bottom: .35rem;
    }
    .diss-card p {
      font-size: .9rem;
      color: var(--text-muted);
      line-height: 1.55;
      margin: 0;
    }

    /* ── Important Dates: tinted accent treatment.
       Preceding Poster Session sits on body white and Important Dates would land on
       --bg-light (#f7f9fc), which is too close to white to read as a separate section.
       ID specificity (1,0,0) beats `section:nth-child(even)` (0,1,1). */
    #contact {
      background:
        radial-gradient(ellipse 100% 55% at 50% 0%, rgba(0,212,255,.12) 0%, transparent 70%),
        var(--bg-light);
      border-top: 1px solid rgba(0,212,255,.22);
    }

    /* ── Competition callout banner (mirror of competition.html's workshop callout) ──
       Selector specificity bumped to (0,1,1) to beat `section:nth-child(even)` from
       the global stylesheet, which would otherwise paint over the gradient. */
    section.competition-callout {
      background: linear-gradient(135deg, #2d1b69 0%, #c026d3 100%);
      color: #fff;
      padding: 3rem 1.5rem;
    }
    .competition-callout-inner {
      max-width: 880px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .competition-callout h3 {
      color: #fff;
      font-size: clamp(1.25rem, 2.4vw, 1.6rem);
      font-weight: 800;
      margin-bottom: .4rem;
    }
    .competition-callout p {
      color: rgba(255,255,255,.85);
      font-size: .98rem;
      max-width: 520px;
      margin: 0;
    }
    .competition-callout .btn {
      background: #fff;
      color: #2d1b69;
      white-space: nowrap;
    }
    .competition-callout .btn:hover {
      background: #0a0e1a;
      color: #fff;
      transform: translateY(-2px);
    }
    @media (max-width: 640px) {
      .competition-callout-inner { flex-direction: column; text-align: center; }
    }
  </style>
{% endraw %}{% endblock %}

{% block main %}{% raw %}
<main id="main-content">

<!-- ============================================================
     SUB-PAGE HERO
     ============================================================ -->
<section id="home" class="subhero">
  <div class="subhero-content">
    <div class="hero-wordmark hero-wordmark-sm" role="img" aria-label="EBiM Benchmark">
      <span class="hero-wordmark-mark">EBiM</span>
      <span class="hero-wordmark-sub">Benchmark</span>
    </div>

    <div class="breadcrumb" aria-label="面包屑导航">
