      </span>
      <span class="sched-legend-item legend-panel">
        <span class="legend-dot"></span>圆桌
      </span>
      <span class="sched-legend-item legend-award">
        <span class="legend-dot"></span>颁奖
      </span>
      <span class="sched-legend-item legend-lunch">
        <span class="legend-dot"></span>交流
      </span>
    </div>

    <div class="sched-timeline fade-in">

      <!-- 08:30 Opening -->
