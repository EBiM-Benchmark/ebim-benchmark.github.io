<!-- ============================================================
     OVERVIEW (abstract + three-phase pipeline)
     ============================================================ -->
<section id="overview">
  <div class="container">

    <div class="text-center fade-in">
      <h2 class="section-title">概述</h2>
    </div>

    <p class="overview-abstract fade-in">
      移动操作（包括双臂协同）正越来越多地与基础模型和视觉-语言-动作（VLA）系统相结合。然而，机器人学界仍然缺乏能够在真实世界场景中验证这些方法的标准化基准。由于仿真到现实的差距、平台差异以及可复现性有限，仿真结果往往难以转化为稳健的实际部署。本研讨会通过一项结构化的<strong>三阶段计划</strong>，提出一个全球协同的基准化倡议。
    </p>

    <!-- ── Three-Phase Pipeline ── -->
    <div class="pipeline-wrap fade-in" aria-label="三阶段基准流程">
      <div class="pipeline">

        <!-- Phase I -->
        <div class="pipeline-phase">
          <div class="phase-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 56 56" fill="none" aria-hidden="true">
              <rect x="4" y="8" width="48" height="32" rx="4" stroke="currentColor" stroke-width="3"/>
              <path d="M20 46h16M28 40v6" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <path d="M16 22l6 6-6 6M30 34h6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="phase-label">第一阶段</div>
          <h3 class="phase-title">开放仿真基准</h3>
          <p class="phase-desc">
            发布一个开放仿真基准，聚焦于非结构化操作场景：线缆布线、可变形材料操作（导热垫放置），以及辅助生活与喂食任务。全球团队通过公开招募，在共享、可复现的排行榜上参与。
          </p>
        </div>

        <!-- Arrow I → II -->
        <div class="pipeline-arrow" aria-hidden="true">
          <svg viewBox="0 0 48 24" xmlns="http://www.w3.org/2000/svg">
            <path class="arrow-line" d="M4 12 H38" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            <path class="arrow-head" d="M32 5 L44 12 L32 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>

        <!-- Phase II -->
        <div class="pipeline-phase">
          <div class="phase-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 56 56" fill="none" aria-hidden="true">
              <circle cx="28" cy="28" r="22" stroke="currentColor" stroke-width="3"/>
              <ellipse cx="28" cy="28" rx="22" ry="9" stroke="currentColor" stroke-width="1.8" opacity=".45"/>
              <line x1="6" y1="28" x2="50" y2="28" stroke="currentColor" stroke-width="1.8" opacity=".45"/>
              <path d="M28 6 Q38 28 28 50" stroke="currentColor" stroke-width="1.8" opacity=".45" fill="none"/>
              <path d="M28 6 Q18 28 28 50" stroke="currentColor" stroke-width="1.8" opacity=".45" fill="none"/>
              <circle cx="17" cy="22" r="3" fill="currentColor"/>
              <line x1="17" y1="22" x2="17" y2="17" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <circle cx="27" cy="17" r="3" fill="currentColor"/>
              <line x1="27" y1="17" x2="27" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <circle cx="28" cy="21" r="3" fill="currentColor"/>
              <line x1="28" y1="21" x2="28" y2="16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <circle cx="38" cy="21" r="3" fill="currentColor"/>
              <line x1="38" y1="21" x2="38" y2="16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="phase-label">第二阶段</div>
          <h3 class="phase-title">跨大洲真实世界验证</h3>
          <p class="phase-desc">
            从仿真晋级的团队将在汉堡、慕尼黑、匹兹堡和上海的合作实验室，于真实的 Mobile FR3 Duo 机器人上进行验证。仿真结果公布后（8 月 8 日），晋级团队将获得在真实平台上的实操调试窗口（8 月 10–19 日）。8 月 20–31 日，团队可继续提交代码，但所有真实机器人的台架测试与评估均由组织方运行 —— 以确保跨站点可比性。
          </p>
        </div>

        <!-- Arrow II → III -->
        <div class="pipeline-arrow" aria-hidden="true">
          <svg viewBox="0 0 48 24" xmlns="http://www.w3.org/2000/svg">
            <path class="arrow-line" d="M4 12 H38" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
            <path class="arrow-head" d="M32 5 L44 12 L32 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </div>

        <!-- Phase III -->
        <div class="pipeline-phase">
          <div class="phase-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 56 56" fill="none" aria-hidden="true">
              <rect x="8" y="6" width="40" height="28" rx="3" stroke="currentColor" stroke-width="3"/>
              <rect x="15" y="22" width="5" height="6" rx="1" fill="currentColor" opacity=".7"/>
              <rect x="23" y="17" width="5" height="11" rx="1" fill="currentColor" opacity=".7"/>
              <rect x="31" y="13" width="5" height="15" rx="1" fill="currentColor"/>
              <line x1="28" y1="34" x2="28" y2="44" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <path d="M16 44 Q28 48 40 44" stroke="currentColor" stroke-width="3" stroke-linecap="round" fill="none"/>
            </svg>
          </div>
          <div class="phase-label">第三阶段</div>
          <h3 class="phase-title">研讨会与路线图发布</h3>
          <p class="phase-desc">
            竞赛结果、特邀报告以及圆桌讨论将在社区研讨会（地点与日期待定）上呈现。研讨会将发布基准协议、开放数据集，以及面向未来迭代的社区路线图。
          </p>
        </div>

      </div><!-- /.pipeline -->
    </div><!-- /.pipeline-wrap -->

  </div>
</section>


