{% block headStyle %}{% raw %}
  <!-- Critical CSS inlined to prevent FOUC + landing-page-specific styles -->
  <style>
    /* Fade-in default state — must be set before JS runs */
    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity .55s ease, transform .55s ease; }
    .fade-in.visible { opacity: 1; transform: none; }
    /* Stagger children inside a fade-in parent */
    .fade-in > *:nth-child(2) { transition-delay: .08s; }
    .fade-in > *:nth-child(3) { transition-delay: .16s; }
    .fade-in > *:nth-child(4) { transition-delay: .24s; }
    .fade-in > *:nth-child(5) { transition-delay: .32s; }
    .fade-in > *:nth-child(6) { transition-delay: .40s; }
    /* Active nav link */
    .nav-links a.active { color: var(--accent) !important; }
    /* Back to top */
    #back-to-top {
      position: fixed; bottom: 2rem; right: 1.5rem;
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--accent, #00d4ff); color: #0a0e1a;
      border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; visibility: hidden; transform: translateY(12px);
      transition: opacity .3s, visibility .3s, transform .3s, background .2s, box-shadow .2s;
      z-index: 998;
      box-shadow: 0 4px 18px rgba(0,212,255,.35);
    }
    #back-to-top.visible { opacity: 1; visibility: visible; transform: none; }
    #back-to-top:hover { background: #fff; box-shadow: 0 6px 24px rgba(0,212,255,.45); }
    #back-to-top:focus-visible { outline: 2px solid #00d4ff; outline-offset: 3px; }
    #back-to-top svg { pointer-events: none; }

    /* ── Two Ways to Engage ── */
    .engage-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.75rem;
      margin-top: 2.5rem;
    }
    @media (max-width: 880px) {
      .engage-grid { grid-template-columns: 1fr; }
    }
    .engage-card {
      background: #fff;
      border: 1px solid rgba(10,14,26,.08);
      border-radius: 18px;
      padding: 2rem 1.75rem 1.75rem;
      display: flex;
      flex-direction: column;
      transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease;
    }
    .engage-card:hover {
      transform: translateY(-6px);
      border-color: rgba(0,212,255,.45);
      box-shadow: 0 16px 40px rgba(10,14,26,.10);
    }
    .engage-icon {
      width: 64px; height: 64px;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(0,212,255,.18), rgba(0,212,255,.05));
      color: var(--accent);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 1.2rem;
    }
    .engage-card h3 {
      font-size: 1.45rem;
      font-weight: 800;
      color: var(--bg-dark);
      margin-bottom: .35rem;
      letter-spacing: -.01em;
    }
    .engage-prize-ribbon {
      display: inline-flex;
      align-items: center;
      gap: .35rem;
      background: rgba(234,179,8,.14);
      color: #a16207;
      border: 1px solid rgba(234,179,8,.35);
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .06em;
      padding: .2rem .65rem;
      border-radius: 100px;
      margin-bottom: .6rem;
    }
    .engage-subtitle {
      font-size: .88rem;
      font-weight: 600;
      letter-spacing: .03em;
      color: var(--accent);
      margin-bottom: 1rem;
    }
    .engage-card p.engage-desc {
      color: var(--text-mid);
      font-size: 1rem;
      line-height: 1.65;
      margin-bottom: 1.2rem;
    }
    .engage-features {
      list-style: none;
      padding: 0;
      margin: 0 0 1.6rem;
    }
    .engage-features li {
      display: flex;
      align-items: center;
      gap: .6rem;
      padding: .45rem 0;
      font-size: .92rem;
      color: var(--text-dark);
      border-bottom: 1px solid rgba(10,14,26,.06);
    }
    .engage-features li:last-child { border-bottom: none; }
    .engage-features li::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
      flex-shrink: 0;
    }
    .engage-card .engage-cta {
      margin-top: auto;
      align-self: flex-start;
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      padding: .8rem 1.6rem;
      border-radius: 8px;
      font-weight: 700;
      font-size: .95rem;
      background: var(--accent);
      color: var(--bg-dark);
      transition: background .2s, color .2s, transform .2s, box-shadow .2s;
    }
    .engage-card .engage-cta:hover {
      background: var(--bg-dark);
      color: #fff;
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(10,14,26,.20);
    }
    .engage-card .engage-cta svg { transition: transform .2s; }
    .engage-card .engage-cta:hover svg { transform: translateX(3px); }

    /* ── Important Dates summary ── */
    .dates-summary {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-top: 2.5rem;
      max-width: 920px;
      margin-left: auto;
      margin-right: auto;
    }
    @media (max-width: 760px) {
      .dates-summary { grid-template-columns: 1fr; }
    }
    .dates-column {
      background: #fff;
      border: 1px solid rgba(10,14,26,.08);
      border-radius: 14px;
      padding: 1.5rem 1.5rem;
      transition: border-color .25s ease, box-shadow .25s ease;
    }
    .dates-column:hover {
      border-color: rgba(0,212,255,.35);
      box-shadow: 0 8px 24px rgba(10,14,26,.06);
    }
    .dates-column-eyebrow {
      font-size: .72rem;
      font-weight: 800;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: .35rem;
    }
    .dates-column h3 {
      font-size: 1.15rem;
      color: var(--bg-dark);
      margin-bottom: 1rem;
      font-weight: 800;
    }
    .dates-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .dates-list li {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1rem;
      padding: .6rem 0;
      border-bottom: 1px dashed rgba(10,14,26,.10);
    }
    .dates-list li:last-child { border-bottom: none; }
    .dates-list .date-name {
      color: var(--text-mid);
      font-size: .92rem;
    }
    .dates-list .date-when {
      color: var(--bg-dark);
      font-weight: 700;
      font-size: .92rem;
      white-space: nowrap;
    }
    .dates-list .date-highlight .date-when { color: var(--accent); }
    .dates-note {
      text-align: center;
      margin-top: 1.5rem;
      color: var(--text-muted);
      font-size: .9rem;
    }
    .dates-note a { color: var(--accent); font-weight: 600; }
    .dates-note a:hover { text-decoration: underline; }
  </style>
{% endraw %}{% endblock %}

