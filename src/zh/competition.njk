{% block headStyle %}{% raw %}
  <!-- Critical CSS inlined to prevent FOUC -->
  <style>
    /* Fade-in default state — must be set before JS runs */
    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity .55s ease, transform .55s ease; }
    .fade-in.visible { opacity: 1; transform: none; }
    /* Stagger children inside a fade-in parent */
    .fade-in > *:nth-child(2) { transition-delay: .08s; }
    .fade-in > *:nth-child(3) { transition-delay: .16s; }
    .fade-in > *:nth-child(4) { transition-delay: .24s; }
    .fade-in > *:nth-child(5) { transition-delay: .32s; }
    .fade-in > *:nth-child(6) { transition-delay: .40s; }
    /* Active nav link */
    .nav-links a.active { color: var(--accent) !important; }
    /* Back to top */
    #back-to-top {
      position: fixed; bottom: 2rem; right: 1.5rem;
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--accent, #00d4ff); color: #0a0e1a;
      border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; visibility: hidden; transform: translateY(12px);
      transition: opacity .3s, visibility .3s, transform .3s, background .2s, box-shadow .2s;
      z-index: 998;
      box-shadow: 0 4px 18px rgba(0,212,255,.35);
    }
    #back-to-top.visible { opacity: 1; visibility: visible; transform: none; }
    #back-to-top:hover { background: #fff; box-shadow: 0 6px 24px rgba(0,212,255,.45); }
    #back-to-top:focus-visible { outline: 2px solid #00d4ff; outline-offset: 3px; }
    #back-to-top svg { pointer-events: none; }

    /* ── Sub-page hero (shorter than home #home) ──
       Selector specificity bumped to (1,1,0) via `#home.subhero` to override
       `#home { min-height: 100vh; padding: ... }` from the global stylesheet.
       Pseudo-element rules likewise override #home::before/::after. */
    #home.subhero {
      min-height: 40vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      background: var(--bg-dark);
      overflow: hidden;
      padding: calc(var(--nav-h) + 2.5rem) 0 3rem;
      box-sizing: border-box;
    }
    #home.subhero::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(0,212,255,.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,212,255,.07) 1px, transparent 1px);
      background-size: 60px 60px;
      animation: none;
      pointer-events: none;
    }
    #home.subhero::after {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(0,212,255,.10) 0%, transparent 70%);
      pointer-events: none;
    }
    .subhero-content {
      position: relative; z-index: 1;
      text-align: center;
      max-width: 820px;
      padding: 1.25rem 1.5rem;
    }
    .breadcrumb {
      display: inline-block;
      font-size: .78rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(255,255,255,.55);
      margin-bottom: 1rem;
    }
    .breadcrumb a {
      color: rgba(255,255,255,.55);
      transition: color .2s;
    }
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb-sep { margin: 0 .55rem; opacity: .5; }
    .breadcrumb-current { color: var(--accent); }
    .subhero-title {
      font-size: clamp(1.7rem, 3.6vw, 2.6rem);
      color: #fff;
      font-weight: 800;
      line-height: 1.18;
      margin-bottom: .9rem;
      letter-spacing: -.01em;
    }
    .subhero-subtitle {
      font-size: clamp(.95rem, 1.6vw, 1.1rem);
      color: rgba(255,255,255,.72);
      margin-bottom: 1.6rem;
      max-width: 640px;
      margin-left: auto; margin-right: auto;
    }
    .subhero-badge {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      background: rgba(234,179,8,.18);
      border: 1px solid rgba(234,179,8,.45);
      color: #fde68a;
      font-size: .85rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      padding: .4rem 1rem;
      border-radius: 100px;
      margin-bottom: 1.2rem;
    }
    .subhero-badge strong { font-weight: 700; }
    .subhero-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
    @media (max-width: 700px) {
      #home.subhero { min-height: 50vh; padding-top: calc(var(--nav-h) + 1.5rem); padding-bottom: 2rem; }
    }

    /* ── Three-Phase context note (Phase III link to workshop page) ── */
    .pipeline-note {
      max-width: 760px;
      margin: 1.75rem auto 0;
      text-align: center;
      font-size: .95rem;
      color: var(--text-muted);
      line-height: 1.6;
    }
    .pipeline-note a { color: var(--accent); font-weight: 600; }
    .pipeline-note a:hover { text-decoration: underline; }

    /* ── Testbed Locations grid ── */
    .testbed-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
      margin-top: 2.5rem;
    }
    @media (max-width: 980px) {
      .testbed-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 520px) {
      .testbed-grid { grid-template-columns: 1fr; }
    }
    .testbed-card {
      background: #fff;
      border: 1px solid rgba(10,14,26,.08);
      border-radius: 14px;
      padding: 1.4rem 1.25rem;
      text-align: center;
      transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    }
    .testbed-card:hover {
      transform: translateY(-4px);
      border-color: rgba(0,212,255,.45);
      box-shadow: 0 10px 30px rgba(10,14,26,.08);
    }
    .testbed-flag {
      display: block;
      width: 40px;
      height: 30px;
      margin: 0 auto .55rem;
      border-radius: 3px;
      border: 1px solid rgba(10,14,26,.08);
      object-fit: cover;
    }
    .testbed-city {
      font-size: 1.15rem;
      font-weight: 800;
      color: var(--bg-dark);
      margin-bottom: .35rem;
      letter-spacing: -.005em;
    }
    .testbed-institution {
      font-size: .9rem;
      font-weight: 600;
      color: var(--accent);
      margin-bottom: .5rem;
    }
    .testbed-role {
      font-size: .85rem;
      color: var(--text-muted);
      line-height: 1.5;
    }
    .testbed-link {
      display: inline-block;
      margin-top: .6rem;
      font-size: .82rem;
      font-weight: 700;
      color: var(--accent-dark);
    }
    .testbed-link:hover { color: var(--accent); }

    /* ── Why This Benchmark ── */
    .why-benchmark p {
      max-width: 880px;
      margin: 1.25rem auto 0;
      font-size: 1.05rem;
      line-height: 1.75;
      color: var(--text-body, #2c3243);
      text-align: left;
    }

    /* ── Workshop callout banner ──
       Selector specificity bumped to (0,1,1) so it beats `section:nth-child(even)`
       from the global stylesheet if section order ever shifts. */
    section.workshop-callout {
      background: linear-gradient(135deg, #0a2a4a 0%, #00b4d8 100%);
      color: #fff;
      padding: 3rem 1.5rem;
    }
    .workshop-callout-inner {
      max-width: 880px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .workshop-callout h3 {
      color: #fff;
      font-size: clamp(1.25rem, 2.4vw, 1.6rem);
      font-weight: 800;
      margin-bottom: .4rem;
    }
    .workshop-callout p {
      color: rgba(255,255,255,.85);
      font-size: .98rem;
      max-width: 520px;
      margin: 0;
    }
    .workshop-callout .btn {
      background: #fff;
      color: #0a2a4a;
      white-space: nowrap;
    }
    .workshop-callout .btn:hover {
      background: #0a0e1a;
      color: #fff;
      transform: translateY(-2px);
    }
    @media (max-width: 640px) {
      .workshop-callout-inner { flex-direction: column; text-align: center; }
    }
    .community-resource-card {
      display: flex;
      gap: 1.1rem;
      align-items: flex-start;
      background: var(--bg-light);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      max-width: 640px;
      text-decoration: none;
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .community-resource-card:hover {
      border-color: var(--accent);
      box-shadow: 0 4px 20px rgba(0,212,255,.08);
    }
  </style>
{% endraw %}{% endblock %}

{% block main %}{% raw %}
<main id="main-content">

<!-- ============================================================
     SUB-PAGE HERO
     ============================================================ -->
<section id="home" class="subhero">
  <div class="subhero-content">
    <div class="hero-wordmark hero-wordmark-sm" role="img" aria-label="EBiM Benchmark">
