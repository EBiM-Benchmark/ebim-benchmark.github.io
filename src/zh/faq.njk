<script>
(function(){
  var faq=document.getElementById('faq'); if(!faq) return;
  var qas=faq.querySelectorAll('.faq-qa');
  qas.forEach(function(qa,i){
    var q=qa.querySelector('.faq-q');
    if(i!==0){qa.classList.remove('is-open');q.setAttribute('aria-expanded','false');}
    q.addEventListener('click',function(){var open=qa.classList.toggle('is-open');q.setAttribute('aria-expanded',open?'true':'false');});
  });
  var cats=faq.querySelectorAll('.faq-cat'), byId={};
  cats.forEach(function(c){byId[c.getAttribute('data-target')]=c;});
  cats.forEach(function(cat){
    cat.addEventListener('click',function(){
      cats.forEach(function(c){c.classList.remove('is-active');});
      cat.classList.add('is-active');
      var t=document.getElementById(cat.getAttribute('data-target'));
      if(t){var _rm=window.matchMedia('(prefers-reduced-motion: reduce)').matches;t.scrollIntoView({behavior:_rm?'auto':'smooth',block:'start'});var f=t.querySelector('.faq-qa');if(f&&!f.classList.contains('is-open')){f.classList.add('is-open');f.querySelector('.faq-q').setAttribute('aria-expanded','true');}}
    });
  });
  if('IntersectionObserver' in window){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){cats.forEach(function(c){c.classList.remove('is-active');});var c=byId[e.target.id];if(c)c.classList.add('is-active');}});},{rootMargin:'-40% 0px -55% 0px'});
    faq.querySelectorAll('.faq-card').forEach(function(c){io.observe(c);});
  }
})();
</script>
