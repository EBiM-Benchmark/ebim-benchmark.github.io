<!-- ============================================================
     REGISTER — state-gated on site.openDayRegistration
     ("open" → live RSVP form | "waitlist" → form + banner + list=waitlist
      | "closed" → no form, closed panel). See _data/site.json.
     ============================================================ -->
<section id="register">
  <div class="container">
    <div class="text-center fade-in">
      <h2 class="section-title">报名</h2>
    </div>

{%- if site.openDayRegistration == "closed" %}

    <div class="od-closed fade-in">
      <div class="od-closed-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>
      <h3>汉堡开放日的报名已截止。</h3>
      <p>如对本次活动有任何疑问，请<a href="{{ links.contact }}">与我们联系</a>。</p>
    </div>

{%- else %}

    <div class="od-notice fade-in">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      <span>免费参加。场地共 80 个席位，其中一批预留给 IJCAI-ECAI 2026 参会者。报名将在席位满员时截止，或于 2026 年 8 月 14 日（周五）10:30 CEST——即活动开始前 72 小时——截止，以先到者为准。请在出行前完成报名，我们无法接待未报名的到场者。席位以邮件确认为准；提交表单尚不等于获得席位。</span>
    </div>

    <div class="reg-card fade-in">

{%- if site.openDayRegistration == "waitlist" %}
      <div class="od-waitlist">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <span>80 个席位已全部满员。您仍可加入候补名单——如有空位，我们会通过邮件通知您。</span>
      </div>
{%- endif %}

      <!-- Native Web3Forms RSVP form. AJAX-first (see open-day-form-script.njk);
           hCaptcha is enabled on this key and enforced server-side, so JS is required to submit. -->
      <form id="openDayForm" action="https://api.web3forms.com/submit" method="POST"
            data-msg-referral="请至少选择一种了解开放日的渠道（或填写&quot;其他&quot;）。"
            data-msg-captcha="请先完成人机验证再提交。"
            data-msg-generic="出现问题，请重试。"
            data-msg-network="网络错误，请稍后重试。"
            data-sending="提交中…"
            data-submit-label="预订席位">

        <div class="reg-form">

          <div class="form-field">
            <label class="form-label" for="full_name">姓名（须与您的照片证件一致） <span class="req" aria-hidden="true">*</span>
              <span class="form-label-note">前台将据此核对您的证件</span></label>
            <input class="form-input" type="text" id="full_name" name="full_name" maxlength="120" required placeholder="您的姓名" />
          </div>

          <div class="form-field">
            <label class="form-label" for="email">邮箱 <span class="req" aria-hidden="true">*</span>
              <span class="form-label-note">确认信将发送至此邮箱</span></label>
            <input class="form-input" type="email" id="email" name="email" maxlength="200" required placeholder="you@example.org" />
          </div>

          <div class="form-field">
            <label class="form-label" for="affiliation">单位（院校或机构） <span class="req" aria-hidden="true">*</span></label>
            <input class="form-input" type="text" id="affiliation" name="affiliation" maxlength="200" required placeholder="例如：汉堡大学" />
          </div>

          <div class="form-field">
            <label class="form-label" for="country">国家或地区 <span class="req" aria-hidden="true">*</span></label>
            <input class="form-input" type="text" id="country" name="country" maxlength="120" required placeholder="例如：德国" />
          </div>

          <fieldset class="form-field">
            <legend class="form-label">您是否参加在不来梅举行的 IJCAI-ECAI 2026？ <span class="req" aria-hidden="true">*</span></legend>
            <div class="od-radios">
              <label class="reg-check"><input type="radio" name="ijcai_attendee" value="Yes" required /> <span>是</span></label>
              <label class="reg-check"><input type="radio" name="ijcai_attendee" value="No" /> <span>否</span></label>
            </div>
          </fieldset>

          <fieldset class="form-field">
            <legend class="form-label">您是否参加下午的实地参观与实验室参访？ <span class="req" aria-hidden="true">*</span>
              <span class="form-label-note">EBiM 评测中心 + 汉堡大学实验室，14:00–17:00</span></legend>
            <div class="od-radios">
              <label class="reg-check"><input type="radio" name="afternoon_visits" value="Yes" required /> <span>是</span></label>
              <label class="reg-check"><input type="radio" name="afternoon_visits" value="No" /> <span>否</span></label>
            </div>
          </fieldset>

          <div class="form-field">
            <label class="form-label" for="dietary">饮食需求 <span class="form-label-note">（选填——午餐由 Google 提供）</span></label>
            <input class="form-input" type="text" id="dietary" name="dietary" maxlength="200" placeholder="例如：素食、坚果过敏" />
          </div>

          <fieldset class="form-field">
            <legend class="form-label">您如何了解到本次开放日？ <span class="req" aria-hidden="true">*</span></legend>
            <div class="reg-checks">
              <label class="reg-check"><input type="checkbox" name="referral" value="Discord" /> <span>Discord</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="WeChat" /> <span>微信</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="Colleague or word of mouth" /> <span>同事或口碑</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="IJCAI-ECAI 2026" /> <span>IJCAI-ECAI 2026</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="X (Twitter)" /> <span>X（推特）</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="LinkedIn" /> <span>领英</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="Mailing list" /> <span>邮件列表</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="Search engine" /> <span>搜索引擎</span></label>
            </div>
            <input class="form-input reg-check-other" type="text" name="referral_other" maxlength="200" placeholder="其他（请注明）" />
          </fieldset>

          <!-- ── Consent ── -->
          <div class="form-field">
            <div class="reg-checks">
              <label class="reg-check">
                <input type="checkbox" name="consent_guestlist" value="Yes" required />
                <span>我同意将我的姓名与单位提供给 Google Germany GmbH 以办理入楼权限。（必填——场地无法接待未列入名单的来宾。） <span class="req" aria-hidden="true">*</span></span>
              </label>
              <label class="reg-check">
                <input type="checkbox" name="consent_media_notice" value="Yes" required />
                <span>我了解本次活动将进行拍照与录制，相关影像可能由 EBiM 组织方及合作伙伴公开发布。 <span class="req" aria-hidden="true">*</span></span>
              </label>
              <label class="reg-check">
                <input type="checkbox" name="media_optout" value="Yes" />
                <span>请不要将我收录进公开发布的照片或录像中。</span>
              </label>
            </div>
          </div>

          <!-- Hidden Web3Forms fields -->
          <input type="hidden" name="access_key" value="d6f9fc0c-13e6-473f-b8a1-adc21f267e6b" />
          <input type="hidden" name="from_name" value="EBiM Benchmark — Open Day Hamburg" />
          <input type="hidden" name="subject" value="[OPEN DAY HAMBURG] New registration" />
          <input type="hidden" name="redirect" value="https://ebim-benchmark.github.io/zh/open-day-success.html" />
{%- if site.openDayRegistration == "waitlist" %}
          <input type="hidden" name="list" value="waitlist" />
{%- endif %}

          <!-- Honeypot -->
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <!-- hCaptcha (zero-config via web3forms client script, loaded in trailingScripts) -->
          <div class="h-captcha" data-captcha="true"></div>

          <div id="formError" class="form-error" role="alert" hidden>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span id="formErrorText">出现问题，请重试。</span>
          </div>

          <button type="submit" class="btn btn-submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
