<!-- ============================================================
     REGISTER — state-gated on site.openDayRegistration
     ("open" → live RSVP form | "waitlist" → form + banner + list=waitlist
      | "closed" → no form, closed panel). See _data/site.json.
     ============================================================ -->
<section id="register">
  <div class="container">
    <div class="text-center fade-in">
      <h2 class="section-title">Register</h2>
    </div>

{%- if site.openDayRegistration == "closed" %}

    <div class="od-closed fade-in">
      <div class="od-closed-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>
      <h3>Registration for the Hamburg Open Day is closed.</h3>
      <p>If you have a question about the day, please <a href="{{ links.contact }}">get in touch</a>.</p>
    </div>

{%- else %}

    <div class="od-notice fade-in">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
      <span>Free to attend. The venue seats 80, and a block of seats is reserved for IJCAI-ECAI 2026 attendees. Registration closes when the seats are full, or at 10:30 CEST on Friday 14 August 2026 — 72 hours before the event — whichever comes first. Register before you travel — we cannot admit walk-ins. Your seat is confirmed by email; a submitted form is not yet a seat.</span>
    </div>

    <div class="reg-card fade-in">

{%- if site.openDayRegistration == "waitlist" %}
      <div class="od-waitlist">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
          <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <span>All 80 seats are taken. You can still join the waitlist — we will email you if a place opens up.</span>
      </div>
{%- endif %}

      <!-- Native Web3Forms RSVP form. AJAX-first (see open-day-form-script.njk);
           hCaptcha is enabled on this key and enforced server-side, so JS is required to submit. -->
      <form id="openDayForm" action="https://api.web3forms.com/submit" method="POST"
            data-msg-referral="Please tell us at least one way you heard about the Open Day (or fill in &quot;Other&quot;)."
            data-msg-captcha="Please complete the captcha before submitting."
            data-msg-generic="Something went wrong. Please try again."
            data-msg-network="Network error — please try again later."
            data-sending="Submitting…"
            data-submit-label="Reserve my seat">

        <div class="reg-form">

          <div class="form-field">
            <label class="form-label" for="full_name">Full name, as shown on your photo ID <span class="req" aria-hidden="true">*</span>
              <span class="form-label-note">reception checks this against your ID</span></label>
            <input class="form-input" type="text" id="full_name" name="full_name" maxlength="120" required placeholder="Your full name" />
          </div>

          <div class="form-field">
            <label class="form-label" for="email">Email <span class="req" aria-hidden="true">*</span>
              <span class="form-label-note">your confirmation is sent here</span></label>
            <input class="form-input" type="email" id="email" name="email" maxlength="200" required placeholder="you@example.org" />
          </div>

          <div class="form-field">
            <label class="form-label" for="affiliation">Affiliation (institution / company) <span class="req" aria-hidden="true">*</span></label>
            <input class="form-input" type="text" id="affiliation" name="affiliation" maxlength="200" required placeholder="e.g. University of Hamburg" />
          </div>

          <div class="form-field">
            <label class="form-label" for="country">Country <span class="req" aria-hidden="true">*</span></label>
            <input class="form-input" type="text" id="country" name="country" maxlength="120" required placeholder="e.g. Germany" />
          </div>

          <fieldset class="form-field">
            <legend class="form-label">Are you attending IJCAI-ECAI 2026 in Bremen? <span class="req" aria-hidden="true">*</span></legend>
            <div class="od-radios">
              <label class="reg-check"><input type="radio" name="ijcai_attendee" value="Yes" required /> <span>Yes</span></label>
              <label class="reg-check"><input type="radio" name="ijcai_attendee" value="No" /> <span>No</span></label>
            </div>
          </fieldset>

          <fieldset class="form-field">
            <legend class="form-label">Will you join the afternoon site and lab visits? <span class="req" aria-hidden="true">*</span>
              <span class="form-label-note">EBiM Evaluation Center + University of Hamburg labs, 14:00–17:00</span></legend>
            <div class="od-radios">
              <label class="reg-check"><input type="radio" name="afternoon_visits" value="Yes" required /> <span>Yes</span></label>
              <label class="reg-check"><input type="radio" name="afternoon_visits" value="No" /> <span>No</span></label>
            </div>
          </fieldset>

          <div class="form-field">
            <label class="form-label" for="dietary">Dietary requirements <span class="form-label-note">(optional — lunch is hosted by Google)</span></label>
            <input class="form-input" type="text" id="dietary" name="dietary" maxlength="200" placeholder="e.g. vegetarian, nut allergy" />
          </div>

          <fieldset class="form-field">
            <legend class="form-label">How did you hear about the Open Day? <span class="req" aria-hidden="true">*</span></legend>
            <div class="reg-checks">
              <label class="reg-check"><input type="checkbox" name="referral" value="Discord" /> <span>Discord</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="WeChat" /> <span>WeChat</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="Colleague or word of mouth" /> <span>Colleague or word of mouth</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="IJCAI-ECAI 2026" /> <span>IJCAI-ECAI 2026</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="X (Twitter)" /> <span>X (Twitter)</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="LinkedIn" /> <span>LinkedIn</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="Mailing list" /> <span>Mailing list</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="Search engine" /> <span>Search engine</span></label>
              <label class="reg-check"><input type="checkbox" name="referral" value="The EBiM website" /> <span>The EBiM website</span></label>
            </div>
            <input class="form-input reg-check-other" type="text" name="referral_other" maxlength="200" placeholder="Other (please specify)" />
          </fieldset>

          <!-- ── Consent ── -->
          <div class="form-field">
            <div class="reg-checks">
              <label class="reg-check">
                <input type="checkbox" name="consent_guestlist" value="Yes" required />
                <span>I consent to my name and affiliation being shared with Google Germany GmbH for building access. (Required — the venue cannot admit unlisted guests.) <span class="req" aria-hidden="true">*</span></span>
              </label>
              <label class="reg-check">
                <input type="checkbox" name="consent_media_notice" value="Yes" required />
                <span>I understand that this event will be photographed and recorded, and that images may be published by the EBiM organizers and partners. <span class="req" aria-hidden="true">*</span></span>
              </label>
              <label class="reg-check">
                <input type="checkbox" name="media_optout" value="Yes" />
                <span>Please do not include me in published photos or recordings.</span>
              </label>
            </div>
          </div>

          <!-- Hidden Web3Forms fields -->
          <input type="hidden" name="access_key" value="d6f9fc0c-13e6-473f-b8a1-adc21f267e6b" />
          <input type="hidden" name="from_name" value="EBiM Benchmark — Open Day Hamburg" />
          <input type="hidden" name="subject" value="[OPEN DAY HAMBURG] New registration" />
          <input type="hidden" name="redirect" value="https://ebim-benchmark.github.io/open-day-success.html" />
{%- if site.openDayRegistration == "waitlist" %}
          <input type="hidden" name="list" value="waitlist" />
{%- endif %}

          <!-- Honeypot -->
          <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <!-- hCaptcha (zero-config via web3forms client script, loaded in trailingScripts) -->
          <div class="h-captcha" data-captcha="true"></div>

          <div id="formError" class="form-error" role="alert" hidden>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span id="formErrorText">Something went wrong. Please try again.</span>
          </div>

          <button type="submit" class="btn btn-submit">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11Z"/>
            </svg>
            <span class="btn-label">Reserve my seat</span>
          </button>

          <noscript><p class="reg-noscript">JavaScript is required to complete registration (the spam check needs it). If you can't enable it, email <a href="mailto:organizers@ebim-benchmark.org">organizers@ebim-benchmark.org</a>.</p></noscript>

        </div>
      </form>

      <div id="formSuccess" class="form-success" role="status" hidden>
        <div class="form-success-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="none" viewBox="0 0 24 24"
               stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <h2>Thanks!</h2>
        <p>We have your RSVP. A confirmation email follows; your seat is only held once we confirm it, so please don't travel on this page alone.</p>
        <a href="index.html" class="btn btn-submit" style="max-width:240px;margin:0 auto;">Back to Home</a>
      </div>

    </div>

    <p class="reg-privacy fade-in">We use your information only to organize the EBiM Open Day — including sharing your name and affiliation with Google Germany GmbH for building access. We don't sell it or add you to any mailing list. Submissions are processed by Web3Forms.</p>

{%- endif %}

  </div>
</section>

<!-- ============================================================
     CO-LOCATION
     ============================================================ -->
<section id="co-location">
  <div class="container">
    <div class="text-center fade-in">
      <h2 class="section-title">A co-location event of IJCAI-ECAI 2026</h2>
    </div>

    <p class="od-colocation fade-in">
      The EBiM Open Day — Hamburg is a co-location event of <a href="https://2026.ijcai.org/" target="_blank" rel="noopener">IJCAI-ECAI 2026 <span aria-hidden="true">→</span></a>, the 35th International Joint Conference on Artificial Intelligence, held in Bremen, Germany, 15–21 August 2026.
    </p>

    <p class="od-contact-line fade-in">
      Questions about the Open Day? <a href="{{ links.contact }}">Get in touch <span aria-hidden="true">→</span></a>
    </p>
  </div>
</section>

</main>
