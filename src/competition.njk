      text-align: left;
    }

    /* ── Workshop callout banner ──
       Selector specificity bumped to (0,1,1) so it beats `section:nth-child(even)`
       from the global stylesheet if section order ever shifts. */
    section.workshop-callout {
      background: linear-gradient(135deg, #0a2a4a 0%, #00b4d8 100%);
      color: #fff;
      padding: 3rem 1.5rem;
    }
    .workshop-callout-inner {
      max-width: 880px;
      margin: 0 auto;
