{% block headStyle %}{% raw %}
  <style>
    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity .55s ease, transform .55s ease; }
    .fade-in.visible { opacity: 1; transform: none; }

    /* Active nav link for the current page (FAQ) */
    .page-faq .nav-links a[href="faq.html"] { color: var(--accent); font-weight: 700; }

    /* Back to top */
    #back-to-top {
      position: fixed; bottom: 2rem; right: 1.5rem; width: 44px; height: 44px; border-radius: 50%;
      background: var(--accent, #00d4ff); color: #0a0e1a; border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      opacity: 0; visibility: hidden; transform: translateY(12px);
      transition: opacity .3s, visibility .3s, transform .3s, background .2s, box-shadow .2s;
      z-index: 998; box-shadow: 0 4px 18px rgba(0,212,255,.35);
    }
    #back-to-top.visible { opacity: 1; visibility: visible; transform: none; }
    #back-to-top:hover { background: #fff; box-shadow: 0 6px 24px rgba(0,212,255,.45); }
    #back-to-top:focus-visible { outline: 2px solid #00d4ff; outline-offset: 3px; }
    #back-to-top svg { pointer-events: none; }

    /* ── Sub-page hero (copied from contact.njk — the global stylesheet has no .subhero/.breadcrumb) ── */
    #home.subhero {
      min-height: 32vh; display: flex; align-items: center; justify-content: center;
      position: relative; background: var(--bg-dark); overflow: hidden;
      padding: calc(var(--nav-h) + 2.5rem) 0 3rem; box-sizing: border-box;
    }
    #home.subhero::before {
      content: ''; position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(0,212,255,.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,212,255,.07) 1px, transparent 1px);
      background-size: 60px 60px; pointer-events: none;
    }
    #home.subhero::after {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(0,212,255,.10) 0%, transparent 70%);
      pointer-events: none;
    }
    .subhero-content { position: relative; z-index: 1; text-align: center; max-width: 820px; padding: 1.25rem 1.5rem; }
    .breadcrumb { display: inline-block; font-size: .78rem; letter-spacing: .14em; text-transform: uppercase; color: rgba(255,255,255,.55); margin-bottom: 1rem; }
    .breadcrumb a { color: rgba(255,255,255,.55); transition: color .2s; }
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb-sep { margin: 0 .55rem; opacity: .5; }
    .breadcrumb-current { color: var(--accent); }
    .subhero-title { font-size: clamp(1.7rem, 3.6vw, 2.6rem); color: #fff; font-weight: 800; line-height: 1.18; margin-bottom: .9rem; letter-spacing: -.01em; }
    .subhero-subtitle { font-size: clamp(.95rem, 1.6vw, 1.1rem); color: rgba(255,255,255,.72); margin-bottom: .8rem; max-width: 620px; margin-left: auto; margin-right: auto; }
    .subhero-subtitle a { color: var(--accent); }
    @media (max-width: 700px) { #home.subhero { min-height: 40vh; padding-top: calc(var(--nav-h) + 1.5rem); padding-bottom: 2rem; } }

    /* ── FAQ redesign: category rail + accordion ── */
    #faq { --faq-link: #0e7490; }
    #faq .faq-shell { max-width: 940px; margin: 0 auto; }
    #faq .faq-updated { font-size: .8rem; color: var(--text-muted); margin: 0 0 1.5rem; display: flex; align-items: center; gap: .4rem; }
    #faq .faq-grid { display: flex; gap: 2rem; align-items: flex-start; }
    #faq .faq-rail { flex: 0 0 190px; position: sticky; top: calc(var(--nav-h) + 1rem); display: flex; flex-direction: column; gap: 2px; }
    #faq .faq-rail-h { font-size: .68rem; letter-spacing: .13em; text-transform: uppercase; color: var(--text-muted); font-weight: 700; margin: 0 0 .6rem; padding-left: .7rem; }
    #faq .faq-cat { display: flex; align-items: center; gap: .55rem; width: 100%; padding: .5rem .7rem; border: 0; background: transparent; border-radius: 8px; cursor: pointer; text-align: left; color: var(--text-mid); font-family: inherit; font-size: .84rem; font-weight: 600; border-left: 2px solid transparent; transition: var(--transition); }
    #faq .faq-cat:hover { background: var(--bg-white); color: var(--text-dark); }
    #faq .faq-cat.is-active { color: var(--text-dark); border-left-color: var(--accent); background: var(--bg-white); }
    #faq .faq-cat-n { flex: 1; }
    #faq .faq-cat-c { font-size: .72rem; color: var(--text-muted); }
    #faq .faq-cards { flex: 1 1 auto; min-width: 0; display: flex; flex-direction: column; gap: 1rem; }
    /* cards are <section>s: padding:0 cancels the global "section { padding: 5rem 0 }" bleed */
    #faq .faq-card { background: var(--bg-white); border: 1px solid var(--border); border-radius: 12px; box-shadow: var(--card-shadow); overflow: hidden; padding: 0; scroll-margin-top: calc(var(--nav-h) + 1rem); }
    #faq .faq-card-h { display: flex; align-items: center; gap: .6rem; padding: .85rem 1.1rem; border-bottom: 1px solid var(--border); }
    #faq .faq-card-h h2 { font-size: .95rem; font-weight: 800; color: var(--text-dark); margin: 0; flex: 1; }
    #faq .faq-card-c { font-size: .72rem; color: var(--text-muted); }
    #faq .faq-ico { flex-shrink: 0; }
    #faq .faq-cat .faq-ico { width: 17px; height: 17px; color: var(--text-muted); transition: color var(--transition); }
    #faq .faq-cat.is-active .faq-ico { color: var(--accent); }
    #faq .faq-card-h .faq-ico { width: 18px; height: 18px; color: var(--accent); }
    #faq .faq-qa { border-bottom: 1px solid var(--border); }
    #faq .faq-qa:last-child { border-bottom: 0; }
    #faq .faq-q { width: 100%; display: flex; align-items: center; gap: .7rem; padding: .8rem 1.1rem; background: transparent; border: 0; cursor: pointer; font-family: inherit; text-align: left; color: var(--text-dark); font-size: .9rem; font-weight: 700; border-left: 2px solid transparent; transition: background .16s; }
    #faq .faq-q:hover { background: var(--bg-light); }
    #faq .faq-q-t { flex: 1; }
    #faq .faq-chev { flex-shrink: 0; color: var(--text-muted); transition: transform .25s, color .25s; }
    #faq .faq-qa.is-open > .faq-q { border-left-color: var(--accent); color: var(--faq-link); }
    #faq .faq-qa.is-open .faq-chev { transform: rotate(180deg); color: var(--accent); }
    #faq .faq-a { max-height: 0; overflow: hidden; visibility: hidden; transition: max-height .3s ease, visibility 0s .3s; }
    #faq .faq-qa.is-open .faq-a { max-height: 560px; visibility: visible; transition: max-height .3s ease, visibility 0s 0s; }
    #faq .faq-a p { margin: 0; padding: .1rem 1.1rem 1rem 2rem; font-size: .86rem; line-height: 1.62; color: var(--text-mid); }
    #faq .faq-a a { color: var(--faq-link); text-decoration: none; border-bottom: 1px solid rgba(14,116,144,.32); }
    #faq .faq-a a:hover { border-bottom-color: var(--faq-link); }
    #faq .faq-q:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }
    #faq .faq-cat:focus-visible { outline: 2px solid var(--accent); outline-offset: 1px; }
    @media (max-width: 680px) {
      #faq .faq-grid { flex-direction: column; gap: 1.25rem; }
      #faq .faq-rail { flex-basis: auto; position: static; flex-direction: row; flex-wrap: wrap; gap: 6px; }
      #faq .faq-rail-h { display: none; }
      #faq .faq-cat { width: auto; border-left: 0; border: 1px solid var(--border); }
      #faq .faq-cat.is-active { border-color: var(--accent); }
    }
    @media (prefers-reduced-motion: reduce) {
      #faq .faq-a, #faq .faq-chev, #faq .faq-cat, #faq .faq-q, #faq .faq-ico { transition: none; }
    }
  </style>
{% endraw %}{% endblock %}

