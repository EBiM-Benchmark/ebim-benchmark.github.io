{# Shared <head> tail — favicon, font preload, and the inlined main CSS.
   Duplicated verbatim across every page in the hand-authored site; centralized
   here. The descriptive comments only existed on the four "full" pages
   (index/competition/workshop/contact), so they are gated on `headComments`. #}
{%- if headComments %}
  <!-- Favicon -->
{%- endif %}
  <link rel="icon" type="image/svg+xml" href="{{ assetBase }}img/favicon.svg" />

{%- if headComments %}
  <!-- Fonts — self-hosted Inter (woff2); preload the hero/LCP weight (800) -->
{%- endif %}
  <link rel="preload" as="font" type="font/woff2" crossorigin href="{{ assetBase }}fonts/inter-latin-800-normal.woff2" />

{%- if headComments %}
  <!-- Styles — global sheet inlined (minified) to remove the render-blocking request -->
{%- endif %}
  <style>{{ inlineCss | safe }}</style>
