{#- Renders the index/competition JSON-LD from shared data (see
    _data/eleventyComputed.js `jsonLd`, sourced from _data/event.json +
    _data/i18n/<lang>.json). Each block is deep-equal to the hand-authored
    English block; locales differ only in the translatable strings. -#}
{%- for block in jsonLd %}
  <!-- {{ block.comment }} -->
  <script type="application/ld+json">
  {{ block.data | dump(2) | safe }}
  </script>
{% endfor -%}
