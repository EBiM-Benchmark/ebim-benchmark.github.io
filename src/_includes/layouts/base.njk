<!DOCTYPE html>
<html lang="{{ htmlLang }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
{%- if robots %}
  <meta name="robots" content="{{ robots | safe }}" />
{%- endif %}
{%- if zhNoindex %}
  <meta name="robots" content="noindex" />
{%- endif %}
  <title>{{ (pageMeta.title if pageMeta else title) | safe }}</title>
  <meta name="description" content="{{ (pageMeta.description if pageMeta else description) | safe }}" />
{%- if keywords %}
  <meta name="keywords" content="{{ keywords | safe }}" />
{%- endif %}
{%- if canonical %}

{%- if headComments %}
  <!-- Canonical URL -->
{%- endif %}
  <link rel="canonical" href="{{ canonical | safe }}" />
{%- endif %}
{%- if hreflangAlternates and hreflangAlternates.length %}
{%- for alt in hreflangAlternates %}
  <link rel="alternate" hreflang="{{ alt.hreflang }}" href="{{ alt.href | safe }}" />
{%- endfor %}
{%- endif %}
{%- if siteVerification %}

  <!-- Google Search Console verification -->
  <meta name="google-site-verification" content="-6Ks2ufYwQEMK_F0Erqoj6Fbw5qLqbhbwywmAgTgJJA" />
{%- endif %}

{% block headStructured %}{% endblock %}
{% include "head.njk" %}

{% block headStyle %}{% endblock %}
</head>
<body class="{{ bodyClass }}">

{% include "navbar.njk" %}

{% block main %}{% endblock %}

{% include "footer.njk" %}
{%- if backToTop %}

<!-- Back to top -->
<button id="back-to-top" aria-label="Back to top">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24"
       stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
       aria-hidden="true">
    <polyline points="18 15 12 9 6 15"/>
  </svg>
</button>
{%- endif %}

<script src="{{ assetBase }}js/main.js" defer></script>
{% block trailingScripts %}{% endblock %}
</body>
</html>
