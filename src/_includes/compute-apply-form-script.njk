{% raw %}
<!-- Compute-application form: AJAX submission (honeypot only; unlisted page). -->
<script>
  (function () {
    'use strict';
    var form = document.querySelector('#computeForm');
    if (!form) return;
    var errorBox = document.querySelector('#formError');
    var errorText = document.querySelector('#formErrorText');
    var successEl = document.querySelector('#formSuccess');
    var d = form.dataset;

    function showError(msg) { errorText.textContent = msg || d.msgGeneric; errorBox.hidden = false; errorBox.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
    function showSuccess() { form.hidden = true; successEl.hidden = false; successEl.scrollIntoView({ behavior: 'smooth', block: 'center' }); }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      errorBox.hidden = true;
      var submitBtn = form.querySelector('button[type=submit]');
      var submitLabel = submitBtn.querySelector('.btn-label') || submitBtn;
      submitBtn.disabled = true; submitLabel.textContent = d.sending;
      try {
        var res = await fetch('https://api.web3forms.com/submit', { method: 'POST', headers: { 'Accept': 'application/json' }, body: new FormData(form) });
        var json = await res.json();
        if (json.success) showSuccess();
        else showError(json.message || d.msgGeneric);
      } catch (err) {
        showError(d.msgNetwork);
      } finally {
        submitBtn.disabled = false; submitLabel.textContent = d.submitLabel;
      }
    });
  })();
</script>
{% endraw %}
