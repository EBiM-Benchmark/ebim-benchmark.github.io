{% raw %}
<!-- Compute-application form: AJAX submission (honeypot only; unlisted page). -->
<script>
  (function () {
    'use strict';
    var form = document.querySelector('#computeForm');
    if (!form) return;
    var errorBox = document.querySelector('#formError');
    var errorText = document.querySelector('#formErrorText');
    var successEl = document.querySelector('#formSuccess');
    var d = form.dataset;

    function showError(msg) { errorText.textContent = msg || d.msgGeneric; errorBox.hidden = false; errorBox.scrollIntoView({ block: 'center' }); }
    function showSuccess() { form.hidden = true; successEl.hidden = false; successEl.scrollIntoView({ block: 'center' }); }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      errorBox.hidden = true;
      // Require at least one resource; allow at most one Computational Freedom tier.
      var picked = Array.prototype.slice.call(form.querySelectorAll('input[name="resources"]:checked'));
      if (picked.length === 0) { showError(d.msgResources); return; }
      var cfPicked = picked.filter(function (c) { return c.value.indexOf('Computational Freedom') === 0; });
      if (cfPicked.length > 1) { showError(d.msgCfone); return; }
      // "Email to receive redemption details" is optional — default it to the PoC email when left blank.
      var redemption = form.querySelector('#redemption_email');
      var poc = form.querySelector('#poc_email');
      if (redemption && poc && !redemption.value.trim()) redemption.value = poc.value.trim();
      var submitBtn = form.querySelector('button[type=submit]');
      var submitLabel = submitBtn.querySelector('.btn-label') || submitBtn;
      submitBtn.disabled = true; submitLabel.textContent = d.sending;
      try {
        var res = await fetch('https://api.web3forms.com/submit', { method: 'POST', headers: { 'Accept': 'application/json' }, body: new FormData(form) });
        var json = await res.json();
        if (json.success) showSuccess();
        else showError(json.message || d.msgGeneric);
      } catch (err) {
        showError(d.msgNetwork);
      } finally {
        submitBtn.disabled = false; submitLabel.textContent = d.submitLabel;
      }
    });
  })();
</script>
{% endraw %}
